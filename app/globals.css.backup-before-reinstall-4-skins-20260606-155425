:root {
  --ct-bg: #eef3f7;
  --ct-surface: #ffffff;
  --ct-surface-2: #f4f7fa;
  --ct-surface-3: #e7eef4;
  --ct-text: #142332;
  --ct-muted: #647589;
  --ct-border: #bed0df;
  --ct-border-soft: #d7e2eb;
  --ct-accent: #1f6fb2;
  --ct-accent-soft: #d9ebfa;
  --ct-good: #157f55;
  --ct-warn: #b87512;
  --ct-danger: #b83a3a;
  --ct-finance: #6251bf;
  --ct-share: #1b7d8b;
  --ct-shadow: 0 18px 45px rgba(31, 55, 78, 0.12);
  --ct-radius: 22px;
  --ct-small-radius: 13px;
}
* { box-sizing: border-box; }
html, body { margin: 0; min-height: 100%; }
body {
  background: radial-gradient(circle at top left, rgba(44, 111, 178, 0.13), transparent 34%), var(--ct-bg);
  color: var(--ct-text);
  font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
}
a { color: inherit; text-decoration: none; }
button { font: inherit; }
.ct-app-shell { width: min(1480px, calc(100% - 32px)); margin: 24px auto 60px; }
.ct-hero {
  display: flex; justify-content: space-between; gap: 24px; align-items: flex-start;
  padding: 28px; background: rgba(255,255,255,0.9); border: 1px solid var(--ct-border);
  border-radius: calc(var(--ct-radius) + 6px); box-shadow: var(--ct-shadow); position: relative; overflow: hidden;
}
.ct-hero h1 { margin: 4px 0 10px; font-size: clamp(28px, 4vw, 48px); line-height: 1.02; }
.ct-hero p { margin: 0; color: var(--ct-muted); max-width: 760px; }
.ct-kicker { text-transform: uppercase; letter-spacing: .14em; font-size: 11px; color: #4c769a; font-weight: 700; }
.ct-user-card { display: flex; gap: 12px; align-items: center; min-width: 240px; padding: 12px; border: 1px solid var(--ct-border-soft); background: var(--ct-surface-2); border-radius: 18px; }
.ct-user-card span:not(.ct-avatar) { display: block; color: var(--ct-muted); font-size: 13px; margin-top: 3px; }
.ct-avatar { width: 46px; height: 46px; border-radius: 50%; display: grid; place-items: center; background: #102b45; color: white; font-weight: 800; }
.ct-tabbar { display: flex; justify-content: space-between; align-items: center; gap: 12px; margin: 16px 0; padding: 8px; background: rgba(255,255,255,.74); border: 1px solid var(--ct-border); border-radius: 999px; box-shadow: 0 10px 30px rgba(31,55,78,.08); }
.ct-main-tabs, .ct-role-tabs { display: flex; gap: 6px; flex-wrap: wrap; }
.ct-main-tabs a, .ct-role-tabs a, .ct-open-switch, .ct-action, .ct-actions a, .ct-view-switches button, .ct-subtabs button, .ct-filter-values button {
  border: 1px solid var(--ct-border-soft); background: var(--ct-surface); border-radius: 999px; padding: 9px 13px; font-size: 13px; color: #29465f;
}
.ct-main-tabs a.active, .ct-role-tabs a.active, .ct-subtabs button.active, .ct-view-switches button.active { background: var(--ct-accent); color: white; border-color: var(--ct-accent); }
.ct-page-title-row { display: flex; justify-content: space-between; gap: 16px; align-items: center; margin: 18px 0 14px; padding: 16px 18px; background: rgba(255,255,255,.72); border: 1px solid var(--ct-border-soft); border-radius: var(--ct-radius); }
.ct-page-title-row h2 { margin: 2px 0 0; font-size: 25px; }
.ct-open-switch { background: #102b45; color: white; border-color: #102b45; white-space: nowrap; }
.ct-grid { display: grid; gap: 16px; }
.ct-grid.two { grid-template-columns: repeat(2, minmax(0, 1fr)); }
.ct-grid.three { grid-template-columns: repeat(3, minmax(0, 1fr)); }
.ct-grid.four { grid-template-columns: repeat(4, minmax(0, 1fr)); }
.ct-panel-link { display: block; }
.ct-panel { position: relative; min-height: 160px; padding: 20px; background: rgba(255,255,255,.92); border: 1px solid var(--ct-border); border-radius: var(--ct-radius); box-shadow: 0 12px 34px rgba(31,55,78,.09); overflow: hidden; }
.ct-panel h3 { margin: 0 0 8px; font-size: 18px; }
.ct-muted { color: var(--ct-muted); }
.ct-metric { margin-top: 16px; display: flex; justify-content: space-between; gap: 12px; padding: 12px; background: var(--ct-surface-2); border: 1px solid var(--ct-border-soft); border-radius: 16px; }
.ct-metric strong { font-size: 20px; }
.ct-metric span { color: var(--ct-muted); }
.ct-chip-row { display: flex; gap: 8px; flex-wrap: wrap; margin-top: 12px; }
.ct-chip { display: inline-flex; align-items: center; gap: 6px; border-radius: 999px; padding: 6px 10px; font-size: 12px; border: 1px solid var(--ct-border-soft); background: var(--ct-surface-2); }
.ct-chip.good { color: var(--ct-good); background: #e6f5ee; border-color: #b8dec9; }
.ct-chip.warn { color: var(--ct-warn); background: #fff2da; border-color: #efce95; }
.ct-chip.danger { color: var(--ct-danger); background: #ffe6e6; border-color: #edbbbb; }
.ct-chip.info { color: var(--ct-accent); background: var(--ct-accent-soft); border-color: #b7d6ef; }
.ct-actions { display: flex; gap: 8px; flex-wrap: wrap; margin-top: 14px; }
.ct-actions.compact { justify-content: flex-end; }
.ct-actions a, .ct-action { color: var(--ct-accent); background: var(--ct-accent-soft); border-color: #b7d6ef; }
.ct-table-wrap { overflow-x: auto; border: 1px solid var(--ct-border-soft); border-radius: 16px; margin-top: 12px; }
.ct-table { width: 100%; border-collapse: collapse; font-size: 14px; }
.ct-table th, .ct-table td { padding: 12px; border-bottom: 1px solid var(--ct-border-soft); text-align: left; }
.ct-table th { background: var(--ct-surface-3); font-size: 12px; text-transform: uppercase; letter-spacing: .08em; color: #46657e; }
.ct-table tr:last-child td { border-bottom: 0; }
.ct-activity-layout, .ct-collection-layout { display: grid; grid-template-columns: 286px minmax(0, 1fr); gap: 16px; align-items: start; }
.ct-filter-panel { position: sticky; top: 16px; padding: 18px; background: rgba(255,255,255,.95); border: 1px solid var(--ct-border); border-radius: var(--ct-radius); box-shadow: 0 10px 28px rgba(31,55,78,.08); }
.ct-filter-panel h3 { margin: 0 0 12px; }
.ct-filter-group { padding: 12px 0; border-top: 1px solid var(--ct-border-soft); }
.ct-filter-group strong { display: block; margin-bottom: 8px; font-size: 13px; }
.ct-filter-values { display: flex; flex-wrap: wrap; gap: 6px; }
.ct-filter-values button { padding: 7px 9px; background: var(--ct-surface-2); color: #314e69; cursor: pointer; }
.ct-log-results, .ct-catalog-results { display: grid; gap: 10px; }
.ct-subtabs, .ct-view-switches { display: flex; gap: 6px; flex-wrap: wrap; padding: 8px; background: rgba(255,255,255,.72); border: 1px solid var(--ct-border-soft); border-radius: 18px; }
.ct-log-row { border: 1px solid var(--ct-border); border-radius: 20px; background: var(--ct-surface); box-shadow: 0 8px 22px rgba(31,55,78,.08); overflow: hidden; }
.ct-log-row summary { list-style: none; cursor: pointer; display: grid; grid-template-columns: 44px minmax(220px, 1.4fr) repeat(4, minmax(100px, .7fr)); gap: 10px; align-items: center; padding: 12px; }
.ct-log-row summary::-webkit-details-marker { display: none; }
.ct-log-icon { width: 38px; height: 38px; border-radius: 13px; display: grid; place-items: center; color: white; font-weight: 900; font-size: 20px; }
.ct-log-row.danger .ct-log-icon { background: var(--ct-danger); }
.ct-log-row.finance .ct-log-icon { background: var(--ct-finance); }
.ct-log-row.success .ct-log-icon { background: var(--ct-good); }
.ct-log-row.share .ct-log-icon { background: var(--ct-share); }
.ct-log-main strong { display: block; }
.ct-log-main em { color: var(--ct-muted); font-style: normal; font-size: 13px; }
.ct-log-field { background: var(--ct-surface-3); border: 1px solid var(--ct-border-soft); border-radius: 12px; padding: 9px; font-size: 13px; color: #29465f; }
.ct-log-detail { margin: 0 12px 12px 66px; padding: 16px; border: 1px solid var(--ct-border-soft); border-radius: 18px; background: #f1f5f8; }
.ct-detail-grid { display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: 10px; margin-top: 12px; }
.ct-detail-grid span { padding: 10px; border: 1px solid var(--ct-border-soft); border-radius: 13px; background: var(--ct-surface); color: var(--ct-muted); }
.ct-detail-grid strong { display: block; color: var(--ct-text); margin-bottom: 3px; }
.ct-view-switches { margin: 0 0 4px; }
.ct-object-row { display: grid; grid-template-columns: 82px minmax(260px, 1fr) 130px 130px 160px; gap: 14px; align-items: center; padding: 14px; background: rgba(255,255,255,.95); border: 1px solid var(--ct-border); border-radius: 22px; box-shadow: 0 8px 24px rgba(31,55,78,.08); position: relative; overflow: hidden; }
.ct-object-image { width: 72px; height: 72px; border-radius: 18px; display: grid; place-items: center; background: linear-gradient(140deg, #d5e6f4, #fff); border: 1px solid var(--ct-border-soft); color: #8b6b12; font-weight: 900; font-size: 28px; }
.ct-object-row h3 { margin: 0 0 5px; font-size: 16px; }
.ct-object-row p { margin: 0; color: var(--ct-muted); font-size: 13px; }
.ct-object-value strong { display: block; }
.ct-object-value span { color: var(--ct-good); font-size: 13px; }
.ct-signature-box::after { content: ''; position: absolute; right: 18px; bottom: 13px; width: 150px; height: 1px; background: linear-gradient(to right, transparent, rgba(92,128,158,.42)); pointer-events: none; }
.ct-signature-box::before { content: 'Collectium'; position: absolute; right: 18px; bottom: 7px; font-size: 8px; color: rgba(92,128,158,.72); font-style: italic; pointer-events: none; }
@media (max-width: 980px) { .ct-grid.three, .ct-grid.four { grid-template-columns: repeat(2, minmax(0, 1fr)); } .ct-hero { flex-direction: column; } .ct-object-row { grid-template-columns: 72px minmax(0, 1fr); } .ct-object-status, .ct-object-value, .ct-object-row .ct-actions { grid-column: 2; justify-content: flex-start; } .ct-log-row summary { grid-template-columns: 44px minmax(160px, 1fr) repeat(2, minmax(90px, .6fr)); } .ct-log-field:nth-of-type(n+3) { display: none; } .ct-detail-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); } }
@media (max-width: 700px) { .ct-app-shell { width: min(100% - 18px, 720px); margin-top: 10px; } .ct-tabbar, .ct-page-title-row { border-radius: 20px; align-items: stretch; flex-direction: column; } .ct-main-tabs, .ct-role-tabs { width: 100%; } .ct-main-tabs a, .ct-role-tabs a { flex: 1 1 auto; text-align: center; } .ct-grid.two, .ct-grid.three, .ct-grid.four { grid-template-columns: 1fr; } .ct-activity-layout, .ct-collection-layout { grid-template-columns: 1fr; } .ct-filter-panel { position: relative; top: 0; order: -1; } .ct-log-row summary { grid-template-columns: 38px 1fr; } .ct-log-field { grid-column: span 1; } .ct-log-detail { margin: 0 10px 10px; } .ct-detail-grid { grid-template-columns: 1fr; } }

/* ============================================================
   COLLECTIUM GLOBAL TEMPLATE V7
   Definering:
   Global shell/topbar/sidebar/pageframe. Startside public route
   har ikke sidebar og ikke PageFrame. App-routes har sidebar.
   ============================================================ */

:root {
  --ct-v7-bg: #eef5f9;
  --ct-v7-paper: #ffffff;
  --ct-v7-soft: #f7fbfd;
  --ct-v7-line: #d7e5ee;
  --ct-v7-line-strong: #bdd2df;
  --ct-v7-text: #102b3d;
  --ct-v7-muted: #65798a;
  --ct-v7-blue: #1f6fb2;
  --ct-v7-blue-dark: #123b5d;
  --ct-v7-shadow: 0 18px 45px rgba(31, 55, 78, .10);
  --ct-v7-sidebar: 300px;
  --ct-v7-topbar: 78px;
}

.ct-shell {
  min-height: 100vh;
  background:
    radial-gradient(circle at top left, rgba(31, 111, 178, .10), transparent 34%),
    var(--ct-v7-bg);
  color: var(--ct-v7-text);
}

.ct-topbar {
  position: sticky;
  top: 0;
  z-index: 90;
  background: rgba(247, 251, 253, .92);
  border-bottom: 1px solid var(--ct-v7-line);
  backdrop-filter: blur(18px);
}

.ct-topbar__inner {
  width: min(86vw, 1680px);
  min-height: var(--ct-v7-topbar);
  margin: 0 auto;
  display: grid;
  grid-template-columns: 240px 1fr auto;
  align-items: center;
  gap: 26px;
}

.ct-topbar__brand {
  display: inline-flex;
  align-items: center;
  gap: 12px;
  color: var(--ct-v7-text);
  font-weight: 900;
  text-decoration: none;
}

.ct-topbar__mark,
.ct-sidebar__logo {
  width: 32px;
  height: 32px;
  display: inline-grid;
  place-items: center;
  border-radius: 9px;
  background: linear-gradient(135deg, #b59546, #1f6fb2);
  color: #fff;
  font-family: Georgia, serif;
  font-weight: 900;
  box-shadow: 0 10px 24px rgba(31, 55, 78, .15);
}

.ct-topbar__nav,
.ct-topbar__actions {
  display: flex;
  align-items: center;
  gap: 10px;
}

.ct-topbar__nav {
  justify-content: center;
}

.ct-topbar__nav a,
.ct-topbar__link,
.ct-topbar__button,
.ct-topbar__primary {
  min-height: 42px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border: 1px solid transparent;
  border-radius: 999px;
  background: transparent;
  color: var(--ct-v7-text);
  padding: 0 15px;
  font: inherit;
  font-weight: 850;
  font-size: 13px;
  text-decoration: none;
  cursor: pointer;
}

.ct-topbar__button,
.ct-topbar__link {
  border-color: var(--ct-v7-line);
  background: rgba(255, 255, 255, .74);
}

.ct-topbar__primary {
  background: var(--ct-v7-blue);
  border-color: var(--ct-v7-blue);
  color: #fff;
  box-shadow: 0 12px 28px rgba(31, 111, 178, .20);
}











.ct-shell__body {
  width: min(86vw, 1680px);
  margin: 0 auto;
  display: grid;
  grid-template-columns: var(--ct-v7-sidebar) minmax(0, 1fr);
  align-items: start;
}

.ct-shell--public .ct-shell__body {
  width: 100%;
  display: block;
}

.ct-shell__main {
  min-width: 0;
}

.ct-sidebar {
  position: sticky;
  top: var(--ct-v7-topbar);
  min-height: calc(100vh - var(--ct-v7-topbar));
  padding: 28px 18px;
  border-right: 1px solid var(--ct-v7-line);
  background: linear-gradient(180deg, rgba(255,255,255,.88), rgba(247,251,253,.72));
}

.ct-sidebar__head {
  display: flex;
  align-items: center;
  gap: 12px;
  margin: 0 0 34px;
  font-weight: 900;
}

.ct-sidebar__eyebrow {
  margin: 0 0 14px;
  color: var(--ct-v7-muted);
  text-transform: uppercase;
  letter-spacing: .17em;
  font-size: 11px;
  font-weight: 800;
}

.ct-sidebar__nav {
  display: grid;
  gap: 8px;
}

.ct-sidebar__item {
  display: grid;
  grid-template-columns: 34px minmax(0, 1fr);
  align-items: center;
  gap: 12px;
  min-height: 46px;
  padding: 7px 10px;
  border: 1px solid transparent;
  border-radius: 16px;
  color: var(--ct-v7-text);
  text-decoration: none;
  font-weight: 850;
}

.ct-sidebar__item:hover,
.ct-sidebar__item.is-active {
  border-color: var(--ct-v7-line);
  background: rgba(255,255,255,.82);
  box-shadow: 0 10px 26px rgba(31, 55, 78, .06);
}

.ct-sidebar__mark {
  width: 30px;
  height: 30px;
  display: inline-grid;
  place-items: center;
  border-radius: 10px;
  background: #e8f2f8;
  color: var(--ct-v7-blue-dark);
  font-size: 10px;
  font-weight: 950;
  letter-spacing: .04em;
}

.ct-sidebar__note {
  margin-top: 34px;
  padding: 16px;
  border: 1px solid var(--ct-v7-line);
  border-radius: 18px;
  background: rgba(255,255,255,.66);
  color: var(--ct-v7-muted);
  line-height: 1.45;
}

.ct-sidebar__note strong {
  display: block;
  color: var(--ct-v7-text);
  margin-bottom: 4px;
}

.ct-page-frame {
  margin: 30px 0 60px 30px;
  padding: 26px;
  border: 1px solid var(--ct-v7-line);
  border-radius: 28px;
  background: rgba(255,255,255,.76);
  box-shadow: var(--ct-v7-shadow);
}

.ct-shell--public .ct-shell__main {
  width: 100%;
}

@media (max-width: 1180px) {
  .ct-topbar__inner {
    width: min(94vw, 980px);
    grid-template-columns: auto 1fr auto;
  }

  .ct-topbar__nav {
    display: none;
  }

  .ct-shell__body {
    width: min(94vw, 980px);
    grid-template-columns: 1fr;
  }

  .ct-sidebar {
    position: relative;
    top: 0;
    min-height: auto;
    border-right: 0;
    border-bottom: 1px solid var(--ct-v7-line);
  }

  .ct-page-frame {
    margin: 18px 0 50px;
  }
}

@media (max-width: 720px) {
  .ct-topbar__inner {
    min-height: 66px;
    gap: 10px;
  }

  .ct-topbar__actions {
    gap: 6px;
  }

  .ct-topbar__link,
  .ct-topbar__button {
    padding: 0 10px;
  }

  .ct-topbar__primary {
    display: none;
  }

  .ct-topbar__brand span:last-child {
    display: none;
  }
}


/* ============================================================
   COLLECTIUM STARTSIDE PUBLIC WIDTH FIX
   Startside skal vÃ¦re public/landing, ikke dashboard.
   Den skal ha luft pÃ¥ sidene og maks ca. 80% bredde pÃ¥ innhold.
   ============================================================ */

.ct-public-startside {
  width: 100%;
  overflow-x: hidden;
}

.ct-public-startside > * {
  width: min(80vw, 1500px);
  margin-left: auto;
  margin-right: auto;
}

.ct-public-startside section,
.ct-public-startside [class*="section"],
.ct-public-startside [class*="hero"] {
  max-width: 100%;
}

.ct-public-startside h1 {
  max-width: 760px;
}

@media (max-width: 1180px) {
  .ct-public-startside > * {
    width: min(92vw, 980px);
  }
}

@media (max-width: 720px) {
  .ct-public-startside > * {
    width: min(92vw, 520px);
  }
}


/* ============================================================
   COLLECTIUM PUBLIC STARTSIDE V7 PDF STYLE
   ============================================================ */

.ctv7-start {
  --paper: #fbf6eb;
  --paper2: #fffaf2;
  --ink: #0d3729;
  --muted: #66756d;
  --green: #0f6a42;
  --gold: #b9872d;
  --line: #eadcc8;
  --shadow: 0 26px 70px rgba(31, 40, 33, .10);
  background:
    radial-gradient(circle at 70% 10%, rgba(26, 108, 74, .07), transparent 30%),
    linear-gradient(180deg, var(--paper2), var(--paper));
  color: var(--ink);
  font-family: Inter, system-ui, sans-serif;
  overflow: hidden;
}

.ctv7-hero,
.ctv7-section {
  width: min(80vw, 1500px);
  margin: 0 auto;
  position: relative;
}

.ctv7-hero {
  min-height: calc(100vh - 88px);
  display: grid;
  grid-template-columns: minmax(0, .95fr) minmax(420px, .92fr);
  align-items: center;
  gap: clamp(3rem, 8vw, 8rem);
  padding: clamp(4rem, 8vw, 8rem) 0;
}

.ctv7-watermark {
  position: absolute;
  top: -1rem;
  right: -4vw;
  font-family: Georgia, serif;
  font-size: clamp(7rem, 18vw, 19rem);
  line-height: .8;
  font-weight: 900;
  letter-spacing: .08em;
  color: rgba(177, 143, 90, .08);
  pointer-events: none;
  white-space: nowrap;
}

.ctv7-eyebrow {
  margin: 0 0 1rem;
  text-transform: uppercase;
  letter-spacing: .16em;
  color: var(--green);
  font-size: .78rem;
  font-weight: 950;
}

.ctv7-hero h1,
.ctv7-section h2,
.ctv7-feature-panel h2 {
  margin: 0;
  font-family: Georgia, serif;
  line-height: .92;
  letter-spacing: -.055em;
  color: var(--ink);
}

.ctv7-hero h1 {
  font-size: clamp(5rem, 8.4vw, 9.4rem);
}

.ctv7-section h2,
.ctv7-feature-panel h2 {
  font-size: clamp(2.7rem, 5vw, 5.8rem);
  max-width: 760px;
}

.ctv7-lead {
  margin: 1.5rem 0 0;
  max-width: 760px;
  font-family: Georgia, serif;
  font-style: italic;
  color: var(--green);
  font-size: clamp(1.45rem, 2vw, 2.05rem);
  line-height: 1.22;
}

.ctv7-text {
  margin: 1.7rem 0 0;
  max-width: 760px;
  color: var(--muted);
  font-size: 1.06rem;
  line-height: 1.7;
}

.ctv7-actions,
.ctv7-chiprow {
  display: flex;
  flex-wrap: wrap;
  gap: .8rem;
  margin-top: 1.8rem;
}

.ctv7-button,
.ctv7-plan a {
  display: inline-flex;
  min-height: 46px;
  align-items: center;
  justify-content: center;
  border: 1px solid var(--line);
  border-radius: 999px;
  background: rgba(255,255,255,.78);
  color: var(--ink);
  padding: 0 1.4rem;
  font-weight: 900;
  text-decoration: none;
  box-shadow: 0 10px 24px rgba(31, 40, 33, .06);
}

.ctv7-button--primary {
  background: var(--green);
  border-color: var(--green);
  color: #fffaf2;
}

.ctv7-chiprow span {
  display: inline-flex;
  border: 1px solid var(--line);
  border-radius: 999px;
  background: rgba(239,231,213,.72);
  padding: .5rem .85rem;
  font-weight: 850;
  color: var(--ink);
}

.ctv7-object-demo,
.ctv7-preview-card,
.ctv7-feature-panel {
  border: 1px solid var(--line);
  border-radius: 26px;
  background: rgba(255,250,242,.76);
  box-shadow: var(--shadow);
  padding: 1.5rem;
}

.ctv7-demo-tabs {
  display: inline-flex;
  gap: .3rem;
  padding: .25rem;
  border: 1px solid var(--line);
  border-radius: 999px;
  background: rgba(255,255,255,.7);
  margin-bottom: 1.4rem;
}

.ctv7-demo-tabs span {
  padding: .6rem 1rem;
  border-radius: 999px;
  font-weight: 900;
}

.ctv7-demo-tabs span:first-child {
  background: var(--green);
  color: #fffaf2;
}

.ctv7-demo-card {
  display: grid;
  grid-template-columns: 190px 1fr;
  gap: 1.8rem;
  align-items: center;
  border: 1px solid var(--line);
  border-radius: 20px;
  padding: 2rem;
  background: rgba(255,255,255,.58);
}

.ctv7-demo-image,
.ctv7-illustration {
  min-height: 150px;
  display: grid;
  place-items: center;
  border: 1px dashed #d7c9b5;
  border-radius: 18px;
  background: rgba(255,255,255,.56);
  color: #8a9890;
}

.ctv7-demo-card h2 {
  margin: .2rem 0;
  font-size: clamp(1.9rem, 2.7vw, 3rem);
  line-height: 1;
}

.ctv7-demo-card strong {
  display: inline-block;
  margin-top: 1rem;
  font-size: 2rem;
  color: var(--ink);
}

.ctv7-section {
  padding: clamp(5rem, 8vw, 8rem) 0;
  border-top: 1px solid var(--line);
}

.ctv7-section--split,
.ctv7-section--catalog,
.ctv7-section--features {
  display: grid;
  grid-template-columns: minmax(0, .86fr) minmax(420px, 1fr);
  align-items: center;
  gap: clamp(3rem, 7vw, 7rem);
}

.ctv7-three {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1.2rem;
}

.ctv7-card,
.ctv7-plan {
  position: relative;
  min-height: 190px;
  border: 1px solid var(--line);
  border-radius: 16px;
  background: rgba(255,250,242,.78);
  box-shadow: 0 20px 50px rgba(31, 40, 33, .07);
  padding: 1.7rem;
}

.ctv7-card h3,
.ctv7-plan h3 {
  margin: 0 0 .6rem;
  font-family: Georgia, serif;
  font-size: 1.8rem;
}

.ctv7-card__sub {
  font-family: Georgia, serif;
  font-style: italic;
  color: var(--green);
}

.ctv7-card p,
.ctv7-plan p,
.ctv7-plan li,
.ctv7-demo-card p {
  color: var(--muted);
  line-height: 1.55;
}

.ctv7-signature {
  position: absolute;
  right: 1.1rem;
  bottom: .65rem;
  font-family: Georgia, serif;
  font-style: italic;
  font-size: .68rem;
  color: #b89b6b;
}

.ctv7-signature:before {
  content: "";
  display: inline-block;
  width: 120px;
  border-bottom: 1px solid #d3bd97;
  margin-right: .5rem;
  transform: translateY(-.25rem);
}

.ctv7-reasons {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: .9rem;
}

.ctv7-reasons div {
  border: 1px solid var(--line);
  border-radius: 12px;
  background: rgba(255,250,242,.72);
  padding: 1rem;
  color: var(--muted);
}

.ctv7-plan-grid {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 1rem;
  margin-top: 2rem;
}

.ctv7-plan {
  min-height: 430px;
  display: flex;
  flex-direction: column;
}

.ctv7-plan.is-active {
  border-color: #2f815e;
  box-shadow: 0 28px 70px rgba(47,129,94,.14);
}

.ctv7-plan__badge {
  align-self: flex-end;
  border-radius: 999px;
  background: var(--green);
  color: #fffaf2;
  padding: .35rem .65rem;
  font-size: .75rem;
  font-weight: 950;
  text-transform: uppercase;
}

.ctv7-plan strong {
  display: block;
  margin-top: 1.5rem;
  font-size: 1.65rem;
}

.ctv7-plan small {
  color: var(--green);
  font-weight: 900;
}

.ctv7-plan ul {
  padding-left: 1rem;
  margin: 1rem 0 1.4rem;
}

.ctv7-plan a {
  margin-top: auto;
  width: 100%;
}

.ctv7-feature-list {
  display: grid;
  gap: .8rem;
  margin-top: 2rem;
}

.ctv7-feature-list button {
  min-height: 62px;
  border: 1px solid var(--line);
  border-radius: 12px;
  background: rgba(255,250,242,.76);
  text-align: left;
  padding: 0 1.4rem;
  font-weight: 950;
  color: var(--ink);
}

.ctv7-feature-list button:first-child {
  background: #2e743f;
  color: #fffaf2;
}

.ctv7-feature-panel {
  min-height: 460px;
  display: grid;
  align-content: center;
  position: relative;
}

.ctv7-feature-panel p {
  color: var(--muted);
  font-size: 1.35rem;
  line-height: 1.55;
}

.ctv7-feature-panel strong {
  color: var(--green);
}

@media (max-width: 1180px) {
  .ctv7-hero,
  .ctv7-section {
    width: min(92vw, 980px);
  }

  .ctv7-hero,
  .ctv7-section--split,
  .ctv7-section--catalog,
  .ctv7-section--features {
    grid-template-columns: 1fr;
  }

  .ctv7-three,
  .ctv7-plan-grid,
  .ctv7-reasons {
    grid-template-columns: repeat(2, 1fr);
  }
}

@media (max-width: 720px) {
  .ctv7-hero,
  .ctv7-section {
    width: min(92vw, 520px);
  }

  .ctv7-hero h1 {
    font-size: clamp(4rem, 18vw, 6rem);
  }

  .ctv7-three,
  .ctv7-plan-grid,
  .ctv7-reasons,
  .ctv7-demo-card {
    grid-template-columns: 1fr;
  }
}
